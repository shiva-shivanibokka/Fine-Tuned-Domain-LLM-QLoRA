# ── Required: HuggingFace token (to download Llama 3.2 — gated model) ────────
# Get yours at https://huggingface.co/settings/tokens
# You must also accept the license at https://huggingface.co/meta-llama/Llama-3.2-3B-Instruct
HF_TOKEN=hf_your_token_here

# ── Required: Where to push the fine-tuned model (your HF Hub repo) ──────────
HF_REPO_ID=your-username/llama-3.2-3b-cuad-legal

# ── Optional: For G-Eval LLM-as-judge scoring ────────────────────────────────
# If set, G-Eval uses Claude Haiku as the judge (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# If no Anthropic key, G-Eval falls back to Groq (free tier available)
GROQ_API_KEY=gsk_your-key-here

# ── Optional: Override the G-Eval judge model ────────────────────────────────
GEVAL_MODEL=claude-haiku-3-5
